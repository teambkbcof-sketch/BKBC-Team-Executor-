<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BKBC Team Executor</title>
  <link rel="manifest" href="manifest.json">
  <style>
    body { background: #050505; color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; margin: 0; padding: 20px; overflow: hidden; }
    .header img { width: 100px; height: 100px; border-radius: 50%; border: 2px solid #ff0000; box-shadow: 0 0 20px #ff0000; margin-bottom: 10px; }
    h2 { color: #ff0000; letter-spacing: 3px; text-shadow: 0 0 10px #ff0000; font-size: 1.5rem; }
    
    .editor-container { position: relative; margin-top: 10px; }
    textarea { width: 100%; height: 300px; background: #0a0a0a; color: #00ff00; border: 2px solid #333; border-radius: 10px; padding: 15px; font-family: 'Consolas', monospace; outline: none; box-sizing: border-box; transition: 0.3s; }
    textarea:focus { border-color: #ff0000; box-shadow: 0 0 10px rgba(255, 0, 0, 0.2); }

    .btns { margin-top: 20px; display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
    button { padding: 12px 20px; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; text-transform: uppercase; transition: 0.2s; min-width: 100px; }
    
    .attach { background: #222; color: #ff0000; border: 1px solid #ff0000; }
    .exec { background: #ff0000; color: white; }
    .clear { background: #333; color: white; }
    button:hover { transform: translateY(-2px); opacity: 0.8; box-shadow: 0 5px 15px rgba(255, 0, 0, 0.3); }

    /* Roblox Stilində Bildiriş */
    #notification {
      position: fixed;
      bottom: -100px;
      right: 20px;
      background: rgba(0, 0, 0, 0.85);
      border-left: 5px solid #ff0000;
      color: white;
      padding: 15px 25px;
      border-radius: 5px;
      font-weight: bold;
      transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      z-index: 1000;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    #notification.show { bottom: 20px; }
    .success-text { color: #00ff00; }
  </style>
</head>
<body>

  <div class="header">
    <img src="https://files.fm/u/9ra4eb2zpb" alt="BKBC Logo">
    <h2>BKBC TEAM EXECUTOR</h2>
  </div>

  <div class="editor-container">
    <textarea id="editor" placeholder="-- BKBC Team Official Executor&#10;-- Skriptinizi bura daxil edin..."></textarea>
  </div>

  <div class="btns">
    <button class="attach" onclick="attach()">ATTACH</button>
    <button class="exec" onclick="execute()">EXECUTE</button>
    <button class="clear" onclick="clearEditor()">CLEAR</button>
  </div>

  <div id="notification">
    <span>BKBC Team Executor - <span class="success-text">SUCCESSF INJECTED</span></span>
  </div>

  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('sw.js');
    }

    function attach() {
      const notify = document.getElementById('notification');
      // Balaca bir gecikmə ilə sanki yüklənirmiş kimi göstərək
      notify.innerText = "Injecting...";
      notify.classList.add('show');
      
      setTimeout(() => {
        notify.innerHTML = 'BKBC Team Executor - <span style="color:#00ff00">SUCCESSFUL INJECTED</span>';
        setTimeout(() => {
          notify.classList.remove('show');
        }, 3000);
      }, 1500);
    }

    function execute() {
      const code = document.getElementById('editor').value;
      if(!code) return alert("Xəta: Skript daxil edilməyib!");
      
      const blob = new Blob([code], {type: 'text/plain'});
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'BKBC_Script.lua';
      a.click();
    }

    function clearEditor() {
      document.getElementById('editor').value = '';
    }
  </script>
</body>
</html>
